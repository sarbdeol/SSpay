// 4. ADD this new model for Login History:
model LoginHistory {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  ipAddress   String
  userAgent   String?
  location    String?
  loginAt     DateTime  @default(now())

  @@index([userId])
  @@index([loginAt])
  @@map("login_history")
}

// 5. ADD this new model for Expense Entries (Expense Manager role):
model ExpenseEntry {
  id            Int       @id @default(autoincrement())
  category      String    // HOUSE_RENT, CAR, DRIVER_SALARY, COOK_SALARY, STAFF_SALARY, MISC, ADMIN_WITHDRAWAL
  expenseDate   DateTime
  description   String?
  amount        Decimal   @db.Decimal(15, 2)
  invoiceImage  String?   // Invoice photo filename
  createdById   Int
  createdByUser User      @relation("ExpenseEntryCreator", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([createdById])
  @@index([category])
  @@index([expenseDate])
  @@map("expense_entries")
}

